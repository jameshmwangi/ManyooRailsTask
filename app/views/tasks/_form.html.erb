<%= form_with(model: task, local: true) do |form| %>
  <% if task.errors.any? %>
    <div id="error_explanation" class="alert alert-danger">
      <ul class="mb-0">
        <% task.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :title, Task.human_attribute_name(:title) %>
    <%= form.text_field :title, class: 'form-control' %>
  </div>

  <div class="form-group">
    <%= form.label :content, Task.human_attribute_name(:content) %>
    <%= form.text_area :content, class: 'form-control', rows: 4 %>
  </div>

  <div class="form-group">
    <%= form.label :deadline_on, Task.human_attribute_name(:deadline_on) %>
    <%= form.date_field :deadline_on, class: 'form-control' %>
  </div>

  <div class="form-group">
    <%= form.label :priority, Task.human_attribute_name(:priority) %>
    <%= form.select :priority, Task.priorities.keys.map { |k| [t("activerecord.enums.task.priority.#{k}"), k] }, { include_blank: true }, class: 'form-control' %>
  </div>

  <div class="form-group">
    <%= form.label :status, Task.human_attribute_name(:status) %>
    <%= form.select :status, Task.statuses.keys.map { |k| [t("activerecord.enums.task.status.#{k}"), k] }, { include_blank: true }, class: 'form-control' %>
  </div>

  <div class="form-group">
    <label>ラベル</label><br>
    <% current_user.labels.each do |label| %>
      <div class="form-check form-check-inline">
        <%= form.check_box :label_ids, { multiple: true, include_hidden: false, class: "form-check-input" }, label[:id], false %>
        <label class="form-check-label"><%= label.name %></label>
      </div>
    <% end %>
  </div>

  <div class="form-group mt-4">
    <%= form.submit (task.new_record? ? '登録する' : '更新する'), id: (task.new_record? ? 'create-task' : 'update-task'), class: 'btn btn-primary' %>
  </div>
<% end %>

<div class="mt-3">
  <%= link_to '戻る', tasks_path, id: 'back' %>
</div>
