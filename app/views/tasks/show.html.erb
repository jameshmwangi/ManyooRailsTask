<h1><%= t('tasks.show.title') %></h1>

<p>
  <strong><%= Task.human_attribute_name(:title) %>:</strong>
  <%= @task.title %>
</p>

<p>
  <strong><%= Task.human_attribute_name(:content) %>:</strong>
  <%= @task.content %>
</p>

<p>
  <strong><%= Task.human_attribute_name(:created_at) %>:</strong>
  <%= @task.created_at.strftime("%Y-%m-%d %H:%M") %>
</p>

<p>
  <strong><%= Task.human_attribute_name(:deadline_on) %>:</strong>
  <%= @task.deadline_on %>
</p>

<p>
  <strong><%= Task.human_attribute_name(:priority) %>:</strong>
  <%= t("activerecord.enums.task.priority.#{@task.priority}") %>
</p>

<p>
  <strong><%= Task.human_attribute_name(:status) %>:</strong>
  <%= t("activerecord.enums.task.status.#{@task.status}") %>
</p>

<p><strong>ラベル:</strong>
  <% @task.labels.each do |label| %>
    <span class="badge badge-info"><%= label.name %></span>
  <% end %>
</p>

<%= link_to t('tasks.show.edit'), edit_task_path(@task), id: 'edit-task' %> |
<%= link_to t('tasks.show.back'), tasks_path, id: 'back' %>
