<style>
  .task-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 20px;
  }

  .task-table th, .task-table td {
    padding: 12px 15px;
    text-align: left;
    border-bottom: 1px solid #ddd;
  }

  .task-table th {
    background-color: #f4f4f4;
  }
</style>

<h1><%= t('tasks.index.title') %></h1>

<table class="task-table">
  <thead>
    <tr>
      <th class="task-title"><%= Task.human_attribute_name(:title) %></th>
      <th class="task-content"><%= Task.human_attribute_name(:content) %></th>
      <th class="task-created-at"><%= Task.human_attribute_name(:created_at) %></th>
      <th colspan="3" class="task-actions">Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @tasks.each do |task| %>
      <tr>
        <td><%= task.title %></td>
        <td><%= task.content %></td>
        <td><%= task.created_at.strftime("%Y-%m-%d %H:%M") %></td>
        <td>
          <%= link_to t('tasks.index.show'), task, class: 'show-task', style: 'margin-right: 10px;' %>
          <%= link_to t('tasks.index.edit'), edit_task_path(task), class: 'edit-task', style: 'margin-right: 10px;' %>
          <%= link_to t('tasks.index.destroy'), task, method: :delete, data: { confirm: t('tasks.index.confirm') }, class: 'destroy-task' %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>
<%= paginate @tasks %>

<br><br>
<%= link_to t('tasks.index.new_task'), new_task_path %>
