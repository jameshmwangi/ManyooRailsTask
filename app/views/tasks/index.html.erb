<h1 class="mb-4"><%= t('tasks.index.title') %></h1>

<%= form_with(scope: :search, url: tasks_path, method: :get, local: true, class: 'search-form form-inline mb-4 p-3 bg-light border rounded', id: 'search_form') do |form| %>

  <div class="form-group mr-3">
    <%= form.label :title, Task.human_attribute_name(:title), class: 'mr-2 font-weight-bold' %>
    <%= form.text_field :title, value: params.dig(:search, :title), class: 'form-control', id: 'search_title' %>
  </div>

  <div class="form-group mr-3">
    <%= form.label :status, Task.human_attribute_name(:status), class: 'mr-2 font-weight-bold' %>
    <%= form.select :status, Task.statuses.keys.map { |k| [t("activerecord.enums.task.status.#{k}"), k] }, { include_blank: true, selected: params.dig(:search, :status) }, class: 'form-control', id: 'search_status' %>
  </div>

  <div class="form-group mr-3">
    <%= form.label :label, 'ラベル', class: 'mr-2 font-weight-bold' %>
    <%= form.select :label, current_user.labels.pluck(:name, :id), { include_blank: true, selected: params.dig(:search, :label) }, class: 'form-control', id: 'search_label' %>
  </div>

  <%= form.submit "検索", id: 'search_task', class: 'btn btn-primary' %>
<% end %>

<table class="table table-striped border-bottom mb-4">
  <thead>
    <tr>
      <th><%= Task.human_attribute_name(:title) %></th>
      <th><%= Task.human_attribute_name(:content) %></th>
      <th><%= Task.human_attribute_name(:created_at) %></th>
      <th><%= link_to Task.human_attribute_name(:deadline_on), sort_deadline_on: true %></th>
      <th><%= link_to Task.human_attribute_name(:priority), sort_priority: true %></th>
      <th><%= Task.human_attribute_name(:status) %></th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @tasks.each do |task| %>
      <tr>
        <td><%= task.title %></td>
        <td><%= task.content %></td>
        <td><%= task.created_at.strftime("%Y-%m-%d %H:%M") %></td>
        <td><%= task.deadline_on %></td>
        <td><%= t("activerecord.enums.task.priority.#{task.priority}") %></td>
        <td><%= t("activerecord.enums.task.status.#{task.status}") %></td>
        <td>
          <%= link_to t('tasks.index.show'), task, class: 'btn btn-sm btn-primary show-task' %>
          <%= link_to t('tasks.index.edit'), edit_task_path(task), class: 'btn btn-sm btn-primary edit-task' %>
          <%= link_to t('tasks.index.destroy'), task, method: :delete, data: { confirm: t('tasks.index.confirm') }, class: 'btn btn-sm btn-danger destroy-task' %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="d-flex justify-content-center mt-4">
  <%= paginate @tasks %>
</div>
