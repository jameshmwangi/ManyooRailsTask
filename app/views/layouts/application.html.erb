<!DOCTYPE html>
<html>
<head>
    <title>CdpWebManyoTask</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">

    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
      <div class="container">
        <%= link_to 'Task App', tasks_path, class: "navbar-brand" %>
        <ul class="navbar-nav ml-auto">
          <% if logged_in? %>

            <% if current_user.admin? %>
              <li class="nav-item"><%= link_to 'ユーザ一覧', admin_users_path, class: "nav-link", id: "users-index" %></li>
              <li class="nav-item"><%= link_to 'ユーザを登録する', new_admin_user_path, class: "nav-link", id: "add-user" %></li>
            <% end %>

            <li class="nav-item"><%= link_to 'タスク一覧', tasks_path, class: "nav-link", id: "tasks-index" %></li>
            <li class="nav-item"><%= link_to 'タスクを登録する', new_task_path, class: "nav-link", id: "new-task" %></li>

            <li class="nav-item"><%= link_to 'ラベル一覧', labels_path, class: "nav-link", id: "labels-index" %></li>
            <li class="nav-item"><%= link_to 'ラベルを登録する', new_label_path, class: "nav-link", id: "new-label" %></li>

            <li class="nav-item"><%= link_to 'アカウント設定', user_path(current_user), class: "nav-link", id: "account-setting" %></li>
            <li class="nav-item"><%= link_to 'ログアウト', session_path(current_user.id), method: :delete, class: "nav-link", id: "sign-out" %></li>

          <% else %>
            <li class="nav-item"><%= link_to 'アカウント登録', new_user_path, class: "nav-link", id: "sign-up" %></li>
            <li class="nav-item"><%= link_to 'ログイン', new_session_path, class: "nav-link", id: "sign-in" %></li>
          <% end %>
        </ul>
      </div>
    </nav>

    <div class="container">
      <% flash.each do |key, message| %>
        <div class="alert alert-<%= key == 'notice' ? 'success' : 'danger' %>">
          <%= message %>
        </div>
      <% end %>

      <%= yield %>
    </div>
</body>
</html>
